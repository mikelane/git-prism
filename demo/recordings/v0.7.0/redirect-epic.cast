[0.305, "o", "\u001b[2m# Dry-run prints the full merged settings.json. Filtering down to\u001b[0m\r\n\u001b[2m# just the git-prism redirect entries the install would add.\u001b[0m\r\n"]
[0.234, "o", "[\r\n  {\r\n    \"matcher\": \"Bash\",\r\n    \"command\": \"bash ~/.claude/hooks/git-prism-redirect.sh\",\r\n    \"if\": \"Bash(git diff *)\",\r\n    \"type\": \"command\"\r\n  },\r\n  {\r\n    \"matcher\": \"Bash\",\r\n    \"command\": \"bash ~/.claude/hooks/git-prism-redirect.sh\",\r\n    \"if\": \"Bash(git log *)\",\r\n    \"type\": \"command\"\r\n  },\r\n  {\r\n    \"matcher\": \"Bash\",\r\n    \"command\": \"bash ~/.claude/hooks/git-prism-redirect.sh\",\r\n    \"if\": \"Bash(git show *)\",\r\n    \"type\": \"command\"\r\n  },\r\n  {\r\n    \"matcher\": \"Bash\",\r\n    \"command\": \"bash ~/.claude/hooks/git-prism-redirect.sh\",\r\n    \"if\": \"Bash(git blame *)\",\r\n    \"type\": \"command\"\r\n  },\r\n  {\r\n    \"matcher\": \"Bash\",\r\n    \"command\": \"bash ~/.claude/hooks/git-prism-redirect.sh\",\r\n    \"if\": \"Bash(gh pr diff *)\",\r\n    \"type\": \"command\"\r\n  },\r\n  {\r\n    \"matcher\": \"Bash\",\r\n    \"command\": \"bash ~/.claude/hooks/git-prism-redirect.sh\",\r\n    \"if\": \"Bash(gh pr view *)\",\r\n    \"type\": \"command\"\r\n  },\r\n  {\r\n    \"matcher\": \"mcp__github__get_commit\",\r\n    \"command\": \"bash ~/.claude/hooks/git-prism-redirect.sh\",\r\n "]
[0.000, "o", "   \"type\": \"command\"\r\n  },\r\n  {\r\n    \"matcher\": \"mcp__github__list_commits\",\r\n    \"command\": \"bash ~/.claude/hooks/git-prism-redirect.sh\",\r\n    \"type\": \"command\"\r\n  }\r\n]\r\n"]
