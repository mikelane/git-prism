[0.000, "o", "\u001b[1;34mв•‘\u001b[0m  \u001b[1;36mSegment 2: How the hook works\u001b[0m          \u001b[1;34mв•‘\u001b[0m\r\n"]
[0.000, "o", "\u001b[1;34mв•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ\u001b[0m\r\n\r\n\u001b[2m# The hook is a Claude Code PreToolUse program. It reads a JSON\u001b[0m\r\n"]
[0.000, "o", "\u001b[2m# payload on stdin and decides via exit code: 0 allow, 0+JSON\u001b[0m\r\n"]
[0.000, "o", "\u001b[2m# advisory, 2 block. Drive it directly to see each state.\u001b[0m\r\n\r\n"]
[14.306, "o", "\u001b[1;33m# Block: gh pr diff returns raw text an agent can't use вЂ” exit 2 stops it cold.\u001b[0m\r\n\u001b[1;32m$ \u001b[0m"]
