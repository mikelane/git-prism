[0.001, "o", "\r\n"]
[0.362, "o", "git-prism: gh pr diff returns raw text. Use git-prism instead:\r\n  get_change_manifest(repo_path, base_ref, head_ref, include_function_analysis=true)\r\nStructured per-function change data вЂ” same info, no diff noise.\r\n"]
[0.003, "o", "\u001b[1;31mexit code: 2\u001b[0m\r\n\r\n"]
[12.007, "o", "\u001b[1;33m# Advisory: git diff redirected to get_change_manifest вЂ” exit 0, no interruption.\u001b[0m\r\n"]
[0.000, "o", "\u001b[1;32m$ \u001b[0m"]
[0.012, "o", "echo"]
[0.189, "o", " {.."]
[0.093, "o", ".git"]
[0.094, "o", " dif"]
[0.095, "o", "f ma"]
[0.091, "o", "in.."]
[0.095, "o", "HEAD"]
[0.095, "o", "...}"]
[0.093, "o", " | p"]
[0.095, "o", "ytho"]
[0.095, "o", "n3 h"]
[0.095, "o", "ooks"]
[0.094, "o", "/bas"]
[0.096, "o", "h_re"]
[0.094, "o", "dire"]
[0.096, "o", "ct_h"]
[0.094, "o", "ook."]
[0.188, "o", "py"]
[0.002, "o", "\r\n"]
[0.341, "o", "{\"hookSpecificOutput\": {\"hookEventName\": \"PreToolUse\", \"permissionDecision\": \"allow\", \"additionalContext\": \"git diff between refs returns raw text. git-prism alternative:\\n  get_change_manifest(repo_path, base_ref, head_ref, include_function_analysis=true)\\nReturns structured per-file change data with function-level semantic analysis.\\n\\nYou ran: git diff main..HEAD\"}}\r\n"]
[0.002, "o", "\u001b[1;32mexit code: 0\u001b[0m\r\n\r\n"]
